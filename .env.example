# ============================================================
# .env.example
# このファイルをコピーして .env.local を作成し、値を設定してください。
# .env.local は .gitignore により Git 管理対象外です。
# ============================================================

# サイトの公開 URL（末尾スラッシュなし）
VITE_SITE_URL=https://[YOUR_DOMAIN]

# Netlify フォームを使わず外部サービスを使う場合
# VITE_FORM_ENDPOINT=[YOUR_FORM_ENDPOINT]

# アナリティクス（使用する場合）
# VITE_GA_MEASUREMENT_ID=[YOUR_GA_MEASUREMENT_ID]

# その他 API キー（使用する場合）
# VITE_API_KEY=[YOUR_API_KEY]
